         the target bitrate. There is deliberately no "direct stream" entry — it produced a
         byte-identical 256k transcode, so it was a mislabelled duplicate of "256 kbps (AAC)". -->
    <string-array name="bitrate">
        <item>320 kbps (AAC)</item>
        <item>256 kbps (AAC)</item>
        <item>192 kbps (AAC)</item>
        <item>160 kbps (AAC)</item>
        <item>128 kbps (AAC)</item>
    </string-array>

    <string-array name="bitrateValues">
        <item>320000</item>
        <item>256000</item>
        <item>192000</item>
        <item>160000</item>
        <item>128000</item>
    </string-array>
</resources>