<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Everything is transcoded to AAC over HLS (see MediaItemFactory.forTrack); this only sets
         the target bitrate. There is deliberately no "direct stream" entry — it produced a
         byte-identical 256k transcode, so it was a mislabelled duplicate of "256 kbps (AAC)". -->
    <string-array name="bitrate">
        <item>320 kbps (AAC)</item>
        <item>256 kbps (AAC)</item>
        <item>192 kbps (AAC)</item>
        <item>160 kbps (AAC)</item>
        <item>128 kbps (AAC)</item>
    </string-array>

    <string-array name="bitrateValues">
        <item>320000</item>
        <item>256000</item>
        <item>192000</item>
        <item>160000</item>
        <item>128000</item>
    </string-array>

    <!-- Download budget (bytes). Downloads also stop unconditionally when the head unit's free
         space drops below DownloadStore.MIN_FREE_BYTES, whatever the budget says. -->
    <string-array name="downloadLimit">
        <item>2 GB</item>
        <item>5 GB</item>
        <item>10 GB</item>
        <item>20 GB</item>
        <item>50 GB</item>
    </string-array>

    <string-array name="downloadLimitValues">
        <item>2147483648</item>
        <item>5368709120</item>
        <item>10737418240</item>
        <item>21474836480</item>
        <item>53687091200</item>
    </string-array>
</resources>